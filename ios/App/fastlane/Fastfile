default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Create App Store Connect API key from environment
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false
    )

    # Use automatic code signing
    update_code_signing_settings(
      use_automatic_signing: true,
      path: "App.xcodeproj",
      team_id: ENV["APPLE_TEAM_ID"],
      bundle_identifier: "app.lovable.kampen"
    )

    # Increment build number
    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s,
      xcodeproj: "App.xcodeproj"
    )

    # Build the app (archive)
    build_app(
      project: "App.xcodeproj",
      scheme: "App",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates -sdk iphoneos",
      destination: "platform=iOS,name=Any iOS Device",
      export_options: {
        signingStyle: "automatic",
        teamID: ENV["APPLE_TEAM_ID"]
      }
    )

    # Verify HealthKit entitlement in the signed binary BEFORE upload
    ipa_path = lane_context[SharedValues::IPA_OUTPUT_PATH]
    UI.message("Verifying HealthKit entitlement in #{ipa_path}...")

    Dir.mktmpdir do |tmpdir|
      sh("unzip -o '#{ipa_path}' -d '#{tmpdir}'")
      app_path = Dir.glob("#{tmpdir}/Payload/*.app").first
      UI.user_error!("No .app found in IPA") unless app_path

      entitlements = sh("codesign -d --entitlements - '#{app_path}' 2>/dev/null || true")
      unless entitlements.include?("com.apple.developer.healthkit")
        UI.user_error!("❌ HealthKit entitlement MISSING from signed binary! Aborting upload.")
      end
      UI.success("✅ HealthKit entitlement verified in signed binary")
    end

    # Upload to TestFlight only after verification
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
